rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function roleOf(uid) {
      return userDoc(uid).data.role;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isDoctor(uid) {
      return signedIn() && roleOf(uid) == "doctor";
    }

    function isGovernment(uid) {
      return signedIn() && roleOf(uid) == "government";
    }

    function doctorLinkedToPatient(doctorUid, patientUid) {
      let doctor = userDoc(doctorUid);
      let patient = userDoc(patientUid);
      return isDoctor(doctorUid)
        && (
          ("linkedPatients" in doctor.data && doctor.data.linkedPatients.hasAny([patientUid]))
          || ("linkedDoctorIds" in patient.data && patient.data.linkedDoctorIds.hasAny([doctorUid]))
        );
    }

    function immutableUserFieldsUnchanged() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.vmedId == resource.data.vmedId
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function changedKeysOnly(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    function doctorMedicalUpdate() {
      return changedKeysOnly(["visits", "medications", "documents", "vitals", "vitalsHistory", "healthScore"]);
    }

    function doctorLinkingUpdate() {
      return changedKeysOnly(["linkedDoctors", "linkedDoctorIds"]);
    }

    function selfSafeUpdate() {
      return immutableUserFieldsUnchanged();
    }

    match /users/{userId} {
      // Users can read their own profile.
      // Government accounts can read all user profiles.
      // Linked doctor<->patient pairs can read each other.
      allow get: if isSelf(userId)
        || isGovernment(request.auth.uid)
        || (signedIn() && (
          doctorLinkedToPatient(request.auth.uid, userId)
          || doctorLinkedToPatient(userId, request.auth.uid)
        ));

      // Only government dashboards can list all users.
      allow list: if signedIn() && isGovernment(request.auth.uid);

      // New user can create only their own document.
      allow create: if isSelf(userId) && request.resource.data.uid == request.auth.uid;

      allow delete: if false;

      // Self updates are allowed but immutable fields are locked.
      // Linked doctors can only update medical fields of linked patients.
      // Doctors can also update patient linking fields.
      allow update: if (
          isSelf(userId) && selfSafeUpdate()
        ) || (
          doctorLinkedToPatient(request.auth.uid, userId) && doctorMedicalUpdate()
        ) || (
          isDoctor(request.auth.uid) && doctorLinkingUpdate()
        );
    }

    // Public V-Med login lookup (minimal data only: uid/email/role/status/vmedId).
    // No collection listing allowed.
    match /vmedIndex/{vmedId} {
      allow get: if true;
      allow list: if false;
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.vmedId == vmedId;
      allow delete: if false;
    }
  }
}
