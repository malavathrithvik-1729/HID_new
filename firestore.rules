rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ─────────────────────────────────────────────
    // Null-safe role lookup: returns null if user doc doesn't exist yet.
    function getRole() {
      let uid = request.auth.uid;
      return (request.auth != null && exists(/databases/$(database)/documents/users/$(uid)))
        ? get(/databases/$(database)/documents/users/$(uid)).data.role
        : null;
    }

    // Is the requesting user the owner of this document?
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isDoctor() {
      return getRole() == 'doctor';
    }

    // ── USERS COLLECTION ─────────────────────────────────────────────
    match /users/{userId} {
      // Users can read their own profile, doctors/government can read any, and anyone can read doctor profiles (for search)
      allow read: if isOwner(userId) || getRole() in ['doctor', 'government'] || resource.data.role == 'doctor';
      
      // RESTRICTION: Owner can create their own data
      allow create: if isOwner(userId);
      // RESTRICTION: Owner can update BUT cannot CHANGE 'role', 'status', or 'vmedId'.
      // Validates against the current 'resource.data' to ensure values match exactly.
      allow update: if isOwner(userId) && 
                    request.resource.data.role == resource.data.role &&
                    request.resource.data.status == resource.data.status &&
                    request.resource.data.vmedId == resource.data.vmedId;
      
      // Doctors can update patient history/documents/meds
      allow update: if isDoctor() && (
        request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['visits', 'documents', 'medications', 'patientData', 'linkedDoctors', 'linkedDoctorIds', 'linkedPatients', 'vitalsHistory', 'vitals'])
      );

      // No one can delete users from client side
      allow delete: if false;

      // Subcollections (medications, visits, vitals as separate collections if ever used)
      match /{subcollection}/{document=**} {
        allow read, write: if request.auth != null && (
          isOwner(userId)       ||
          getRole() == 'doctor' ||
          getRole() == 'government'
        );
      }
    }

    // ── VMED INDEX ───────────────────────────────────────────────────
    // Public read is REQUIRED — loginWithVMEDId reads this BEFORE the user
    // is authenticated (to look up the email from their V-Med ID).
    match /vmedIndex/{docId} {
      // 🔓 Must be public: login lookup happens unauthenticated
      allow read: if true;

      // ✅ Only the owner of the UID can create/update their mapping
      allow create, update: if request.auth != null && request.auth.uid == request.resource.data.uid;

      // Never allow client-side deletions of index entries
      allow delete: if false;
    }

    // ── MEDICAL RECORDS ──────────────────────────────────────────────
    match /medical_records/{recordId} {
      allow read: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        getRole() in ['doctor', 'government']
      );
      allow create: if request.auth != null && getRole() == 'doctor';
      allow update: if request.auth != null
        && getRole() in ['doctor', 'government'];
      allow delete: if false;
    }
  }
}
