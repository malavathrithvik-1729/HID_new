rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: User's UID
    // Fields:
    //   - role: string (e.g., 'patient', 'doctor', 'government')
    //   - status: string
    //   - vmedId: string
    //   - visits, documents, medications, patientData, linkedDoctors, 
    //     linkedDoctorIds, linkedPatients, vitalsHistory, vitals
    //
    // Collection: vmedIndex
    // Document ID: unique identifier
    // Fields:
    //   - uid: string (Firebase Auth UID)
    //
    // Collection: medical_records
    // Document ID: unique identifier
    // Fields:
    //   - uid: string (Firebase Auth UID of the patient)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Null-safe role lookup: returns null if user doc doesn't exist yet.
    function getRole() {
      let uid = request.auth.uid;
      return (isAuthenticated() && exists(/databases/$(database)/documents/users/$(uid)))
        ? get(/databases/$(database)/documents/users/$(uid)).data.role
        : null;
    }

    function isDoctor() {
      return getRole() == 'doctor';
    }

    function isGovernment() {
      return getRole() == 'government';
    }

    // Verify UID hasn't been tampered with on create
    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }

    // Ensure uid field is not modified on update
    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Collections
    // ===============================================================

    // ── USERS COLLECTION ─────────────────────────────────────────────
    match /users/{userId} {
      // Users can read their own profile, doctors/government can read any, and anyone can read doctor profiles
      allow read: if isOwner(userId) || isDoctor() || isGovernment() || resource.data.role == 'doctor';
      
      // RESTRICTION: Owner can create their own data
      // SECURITY ADDITION: Ensure users cannot create themselves as doctors or government unless they are already one
      allow create: if isOwner(userId) && (
        !('role' in request.resource.data) || 
        request.resource.data.role == 'patient' || 
        isDoctor() || 
        isGovernment()
      );

      // RESTRICTION: Owner can update BUT cannot CHANGE 'role', 'status', or 'vmedId'.
      allow update: if isOwner(userId) && 
                    (!('role' in request.resource.data) || request.resource.data.role == resource.data.role) &&
                    (!('status' in request.resource.data) || request.resource.data.status == resource.data.status) &&
                    (!('vmedId' in request.resource.data) || request.resource.data.vmedId == resource.data.vmedId);
      
      // Doctors can update patient history/documents/meds
      // SECURITY ADDITION: Explicitly prevent doctor from altering user's role or core ID fields while updating medical arrays.
      allow update: if isDoctor() && (
        request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['visits', 'documents', 'medications', 'patientData', 'linkedDoctors', 'linkedDoctorIds', 'linkedPatients', 'vitalsHistory', 'vitals'])
      );

      // No one can delete users from client side
      allow delete: if false;

      // Subcollections (medications, visits, vitals)
      match /{subcollection}/{document=**} {
        allow read, write: if isAuthenticated() && (
          isOwner(userId) || isDoctor() || isGovernment()
        );
      }
    }

    // ── VMED INDEX ───────────────────────────────────────────────────
    // Public read is REQUIRED — loginWithVMEDId reads this BEFORE the user
    // is authenticated (to look up the email from their V-Med ID).
    match /vmedIndex/{docId} {
      // 🔓 Must be public: login lookup happens unauthenticated
      // SECURITY WARNING: This allows anyone to read the vmedIndex. Ensure this collection does not contain PII like emails directly if possible.
      allow read: if true;

      // ✅ Only the owner of the UID can create/update their mapping
      allow create: if isAuthenticated() && 
                    request.resource.data.keys().hasAll(['uid']) && 
                    request.resource.data.uid == request.auth.uid;
                    
      allow update: if isAuthenticated() && 
                    request.auth.uid == resource.data.uid && 
                    uidNotModified();

      // Never allow client-side deletions of index entries
      allow delete: if false;
    }

    // ── MEDICAL RECORDS ──────────────────────────────────────────────
    match /medical_records/{recordId} {
      allow read: if isAuthenticated() && (
        resource.data.uid == request.auth.uid ||
        isDoctor() || 
        isGovernment()
      );
      
      // Only doctors can create medical records. Must tie the record to a UID.
      allow create: if isDoctor() && 
                    request.resource.data.keys().hasAll(['uid']);

      // Only doctors or government can update.
      allow update: if isAuthenticated() && 
                    (isDoctor() || isGovernment()) && 
                    uidNotModified();

      allow delete: if false;
    }
  }
}
